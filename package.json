{
  "name": "telegram-bridge-mcp",
  "author": {
    "name": "electricessence"
  },
  "version": "7.11.1",
  "description": "Telegram Bridge MCP — An MCP server that bridges AI assistants to a Telegram bot for two-way messaging, confirmations, status updates, and voice transcription.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/electrified-cortex/Telegram-Bridge-MCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/electrified-cortex/Telegram-Bridge-MCP.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "telegram",
    "bot",
    "bridge",
    "ai",
    "llm",
    "agent",
    "multi-agent",
    "copilot",
    "github-copilot",
    "claude",
    "claude-code",
    "cursor",
    "vscode",
    "openai",
    "ollama",
    "platform-agnostic",
    "multi-platform",
    "streamable-http",
    "voice",
    "multi-session"
  ],
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "tsc && node scripts/gen-build-info.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "pair": "node dist/setup.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "tsc --noEmit -p tsconfig.eslint.json && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tsdotnet/queue": "^1.3.2",
    "audio-decode": "^3.10.1",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.43.0",
    "opusscript": "^0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.8.0"
}
